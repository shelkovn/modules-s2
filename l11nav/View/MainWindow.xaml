<Window x:Class="l9_mvvm.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:l9_mvvm"
        mc:Ignorable="d"
        Title="ContactBook" Height="450" Width="300">
    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Background="LightGray">
            <Button Content="Контакты" Command="{Binding ShowContactsCommand}" Margin="2" Padding="10,2"/>
            <Button Content="О программе" Command="{Binding ShowAboutCommand}" Margin="2" Padding="10,2"/>
        </StackPanel>
        <ContentControl Content="{Binding NavigationService.CurrentViewModel}" />

    </DockPanel>
</Window>
