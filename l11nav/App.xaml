<Application x:Class="l9_mvvm.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:l9_mvvm"
             xmlns:vm="clr-namespace:l9_mvvm.ViewModel"
             xmlns:v="clr-namespace:l9_mvvm.View">
    <Application.Resources>
        <DataTemplate DataType="{x:Type vm:ContactListViewModel}">
            <v:ContactListView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AboutViewModel}">
            <v:AboutView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ContactEditViewModel}">
            <v:ContactEditView />
        </DataTemplate>
    </Application.Resources>
</Application>
